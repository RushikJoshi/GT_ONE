# ================ SECURITY & JWT ===================
JWT_SECRET=gt_one_sso_secret_key_2026_64_chars_long_and_secure
JWT_ISSUER=gitakshmi-sso
JWT_ALLOWED_ALGS=HS256

# ================ SESSION & COOKIES ================
SSO_COOKIE_DOMAIN=.gitakshmi.com
SSO_COOKIE_SECURE=true
SSO_COOKIE_SAMESITE=none

# ================ TTL SETTINGS =====================
SSO_AUTH_CODE_TTL_SECONDS=120
SSO_APP_TOKEN_TTL_SECONDS=900

# ================ CORS & REDIRECTS =================
CORS_ALLOWED_ORIGINS=https://gaccess.gitakshmi.com,https://hrms.dev.gitakshmi.com,https://devprojects.gitakshmi.com,http://localhost:5176,http://localhost:5173,http://localhost:5174

# Target application base URLs
