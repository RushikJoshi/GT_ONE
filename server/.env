# ================ SECURITY & JWT ===================
# This MUST match SSO_JWT_SECRET in HRMS server/.env
JWT_SECRET=gt_one_sso_secret_key_2026_64_chars_long_and_secure
JWT_ISSUER=gitakshmi-sso
JWT_ALLOWED_ALGS=HS256

# ================ SESSION & COOKIES ================
SSO_COOKIE_DOMAIN=localhost
SSO_COOKIE_SECURE=false
SSO_COOKIE_SAMESITE=lax

# ================ TTL SETTINGS =====================
SSO_AUTH_CODE_TTL_SECONDS=120
SSO_APP_TOKEN_TTL_SECONDS=900

# ================ CORS & REDIRECTS =================
# Allowed origins for frontend modules
CORS_ALLOWED_ORIGINS=http://localhost:5176,http://localhost:5173,http://localhost:5174,https://sso.gitakshmi.com,https://hrms.gitakshmi.com,https://tms.gitakshmi.com

# Target application base URLs
