PMS_BASE_URL=http://localhost:5175
TMS_BASE_URL=http://localhost:5173

# Allowed redirect whitelist for HRMS
SSO_REDIRECT_ALLOWLIST_HRMS=http://localhost:5176,http://localhost:5176/sso-redirect,http://localhost:5176/employee/dashboard

