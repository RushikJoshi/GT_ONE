# ================================
# --- GT ONE SSO SERVER CONFIG ---
# ================================
NODE_ENV=production
PORT=5004
APP_NAME=GT_ONE_SSO

# ================================
# --- CORE URLS ---
# ================================
BACKEND_URL=https://devgaccess.gitakshmi.com
FRONTEND_URL=https://devgaccess.gitakshmi.com

HRMS_BASE_URL=https://hrms.dev.gitakshmi.com
TMS_BASE_URL=https://devprojects.gitakshmi.com
HRMS_PROVISION_URL=https://hrms.dev.gitakshmi.com/api/sso/provision-tenant

# ================================
# --- DATABASE ---
# ================================
MONGO_URI=mongodb+srv://baldaniyanitesh2003_db_user:nitesh123@nitesh.mfy5jc4.mongodb.net/gitakshmi-one?retryWrites=true&w=majority&appName=Cluster0

# ================================
# --- JWT / SECURITY ---
# ================================
JWT_SECRET=YOUR_64_CHAR_RANDOM_SECRET
JWT_ISSUER=gitakshmi-sso
JWT_ALLOWED_ALGS=HS256

# ================================
# --- SESSION / COOKIES ---
# ================================
SSO_COOKIE_DOMAIN=.gitakshmi.com
SSO_COOKIE_SECURE=true
SSO_COOKIE_SAMESITE=lax

SSO_AUTH_CODE_TTL_SECONDS=120
SSO_APP_TOKEN_TTL_SECONDS=900

# ================================
# --- OTP SETTINGS ---
# ================================
LOGIN_OTP_EXPIRY_SECONDS=30
LOGIN_OTP_RESEND_COOLDOWN_SECONDS=30

# ================================
# --- CORS ---
# ================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5176,https://devgaccess.gitakshmi.com,https://hrms.dev.gitakshmi.com,https://devprojects.gitakshmi.com,https://hrms.gitakshmi.com,https://tms.gitakshmi.com

# ================================
# --- SSO REDIRECT ALLOWLIST ---
# ================================
SSO_REDIRECT_ALLOWLIST_HRMS=http://localhost:5176,https://hrms.dev.gitakshmi.com,https://hrms.dev.gitakshmi.com/sso-redirect,https://hrms.dev.gitakshmi.com/employee/dashboard,https://hrms.dev.gitakshmi.com/tenant/dashboard,https://devgaccess.gitakshmi.com

SSO_REDIRECT_ALLOWLIST_TMS=http://localhost:5173,https://devprojects.gitakshmi.com,https://devprojects.gitakshmi.com/dashboard,https://devgaccess.gitakshmi.com

# ================================
# --- SSO CALLBACK / TRUST ---
# ================================
HRMS_SSO_URL=https://devgaccess.gitakshmi.com/api/login
TMS_CALLBACK_URL=https://devprojects.gitakshmi.com/sso/callback

SSO_TRUSTED_DOMAINS=https://devprojects.gitakshmi.com,https://devgaccess.gitakshmi.com,https://hrms.dev.gitakshmi.com

# ================================
# --- EMAIL (OTP SERVICE) ---
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASS=YOUR_NEW_APP_PASSWORD
MAIL_FROM=GT ONE <YOUR_EMAIL@gmail.com>

# ================================
# --- BYPASS / INTERNAL ---
# ================================
OTP_BYPASS_EMAILS=admin@gitakshmi.com
SSO_SYNC_SECRET=gt_one_shared_sync_secret_999

# ================================
# --- OPTIONAL (RECOMMENDED) ---
# ================================
LOG_LEVEL=info
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true